# 스크래퍼와 SvelteKit 빌드가 공유하는 환경변수. 복사해서 .env 로 사용.
#   cp .env.example .env

# 수집·빌드가 읽는 SQLite 경로(리포 루트 기준 상대경로 권장).
DATABASE_PATH=./data/council.sqlite3

# CLIK 지방의정포털 Open API 키.
# 미설정 시 config.py 의 공개 데모 키로 동작하나, 사용자가 clik.nanet.go.kr 에서
# 회원가입 후 "인증키신청"으로 발급받은 정식 키를 넣는 것을 권장.
CLIK_API_KEY=

# 네이버 뉴스 검색 API('언론이 본 의회' 후보 수집).
# 2026년 NAVER Cloud Platform(API Hub)로 이관됨 — NCP 콘솔에서 '뉴스 검색 API' 신청 후
# 애플리케이션 '인증 정보'의 Client ID / Client Secret 을 설정(계정 인증키 ncp_iam_* 아님).
# 미설정 시 media 수집은 건너뜀.
# 문서: https://api.ncloud-docs.com/docs/naver-api-hub-search-news
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
